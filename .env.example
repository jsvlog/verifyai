# ===== VerifyAI — API Configuration =====
# Copy this file to .env.local and fill in your API keys.

# Primary detection provider: gptzero | originality | sapling | winston | custom
DETECTION_PROVIDER=custom

# Provider API Keys (only set the one matching your provider)
GPTZERO_API_KEY=
ORIGINALITY_API_KEY=
SAPLING_API_KEY=
WINSTON_API_KEY=

# Custom endpoint (for DETECTION_PROVIDER=custom)
DETECTION_ENDPOINT=
DETECTION_API_KEY=

# Plagiarism check provider (optional)
PLAGIARISM_API_KEY=
PLAGIARISM_ENDPOINT=

# Text humanizer provider (optional - uses OpenAI-compatible API)
HUMANIZE_API_KEY=
HUMANIZE_ENDPOINT=
